{
  "name": "mwamba-pos",
  "version": "1.0.0",
  "description": "Mwamba POS Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:react && electron-builder --win --dir",
    "build:react": "cd ../pos && npm run build",
    "build:dir": "npm run build:react && electron-builder --win --dir",
    "build:portable": "npm run build:react && electron-builder --win portable"
  },
  "author": "Mwamba POS",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.mwambapos.app",
    "productName": "MwambaPOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "python/**/*"
    ],
    "extraResources": [
      {
        "from": "../POS-BACKEND",
        "to": "POS-BACKEND",
        "filter": [
          "**/*",
          "!*.pyc",
          "!__pycache__",
          "!**/node_modules",
          "!**/*.sqlite3"
        ]
      },
      {
        "from": "../pos/build",
        "to": "build",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": "../pos/public/logo192.png"
    },
    "portable": {
      "artifactName": "MwambaPOS.exe"
    },
    "asar": true,
    "asarUnpack": [
      "**/POS-BACKEND/**/*",
      "**/python/**/*"
    ]
  }
}
